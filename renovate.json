{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "ignorePaths": [".github/**"],
  "labels": ["dependency"],
  "packageRules": [
    {
      "groupName": "renovate dependencies",
      "groupSlug": "renovate",
      "matchPackageNames": ["ghcr.io/renovatebot/renovate", "renovate"]
    },
    {
      "groupName": "valkey dependencies",
      "groupSlug": "valkey",
      "matchPackageNames": ["docker.io/valkey/valkey", "valkey"]
    },
    {
      "matchUpdateTypes": ["patch", "digest", "pin"],
      "automerge": true,
      "labels": ["dependency", "bump:patch"]
    },
    {
      "matchUpdateTypes": ["minor"],
      "automerge": true,
      "labels": ["dependency", "bump:minor"]
    },
    {
      "matchUpdateTypes": ["major"],
      "labels": ["dependency", "bump:major"]
    }
  ],
  "separateMinorPatch": true,
  "suppressNotifications": ["artifactErrors"],
  "postUpgradeTasks": {
    "commands": ["make gen-golden-all"],
    "fileFilters": ["tests/golden/**"],
    "executionMode": "update"
  }
}
